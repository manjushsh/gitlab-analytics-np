# Example environment variables for GitLab Analytics server
GITLAB_TOKEN=your_gitlab_personal_access_token
GITLAB_PROJECT_ID=your_project_id
GITLAB_API_URL=https://gitlab.com/api/v4

# Date Range Configuration (choose one option):

# Option 1: Last N days (default behavior)
PERIOD_DAYS=30

# Option 2: Get data for last month (previous month from current date)
# USE_LAST_MONTH=true

# Option 3: Get data for a specific month (format: YYYY-MM)
# TARGET_MONTH=2025-07
