{
  "name": "gitlab-analytics",
  "version": "0.0.1",
  "description": "A GitLab analytics tool built with Node.js and TypeScript",
  "main": "dist/index.js",
  "scripts": {
    "build": "pnpm --filter ./server... build && pnpm --filter ./client... build",
    "dev:server": "pnpm --filter ./server... dev",
    "dev:client": "pnpm --filter ./client... dev",
    "start:server": "pnpm --filter ./server... start",
    "start:client": "pnpm --filter ./client... start"
  },
  "devDependencies": {
    "@types/node": "^22.15.19",
    "esbuild": "^0.25.4",
    "ts-node": "^10.9.2",
    "typescript": "^5.8.3"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/manjushsh/gitlab-analytics.git"
  },
  "author": "manjushsh",
  "license": "MIT"
}